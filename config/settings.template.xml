<!-- X4: Foundations Settings Template -->
<root>
  <network>
    <online_features_enabled>true</online_features_enabled>
  </network>
  <gameplay>
    <flight_assist>true</flight_assist>
    <mouse_steering_mode>1</mouse_steering_mode>
    <auto_save_interval>600</auto_save_interval>
  </gameplay>
  <video>
    <resolution>1920x1080</resolution>
    <fullscreen>1</fullscreen>
    <vsync>1</vsync>
  </video>
  <audio>
    <master_volume>0.8</master_volume>
    <music_volume>0.5</music_volume>
  </audio>
</root>
